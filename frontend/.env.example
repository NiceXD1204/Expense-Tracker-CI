# Build-time base URL used by the frontend's axios client (src/api/expenses.js).
# Leave as /api for docker-compose and Kubernetes - nginx proxies /api/* to the
# backend at runtime (see nginx/default.conf.template + the BACKEND_URL env var).
# `npm run dev` already proxies /api -> http://localhost:8000 via vite.config.js,
# so you normally don't need to set this for local development either.
VITE_BACKEND_URL=/api
